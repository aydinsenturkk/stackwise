{
  "name": "@aydinsenturkk/claudekit",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.0.0",
  "description": "Reusable knowledge base of rules, skills, agents, and hooks for Claude Code. Run npx @aydinsenturkk/claudekit in any project to configure it.",
  "type": "module",
  "bin": {
    "claudekit": "bin/claudekit.js"
  },
  "files": [
    "bin/",
    "src/",
    "knowledge/",
    "skills/",
    "agents/",
    "hooks/",
    "settings/",
    "templates/",
    "lib/registry.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0"
  },
  "author": "Aydin Senturk <hello@aydinsenturk.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aydinsenturkk/claudekit.git"
  },
  "homepage": "https://github.com/aydinsenturkk/claudekit#readme",
  "bugs": {
    "url": "https://github.com/aydinsenturkk/claudekit/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "knowledge-base",
    "rules",
    "skills",
    "agents"
  ],
